---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <h1>Welcome to Webflow Cloud</h1>
    <p>This is a simple test using Basic components with enhanced styling.</p>
    <a
      href="https://developers.webflow.com/webflow-cloud/getting-started"
      class="button-primary"
    >
      Get Started
    </a>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 480px;
    padding: 2rem 1.5rem;
    gap: 1rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
    background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  p {
    font-size: 1rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
  }

  .button-primary {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    background: #146ef5;
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .button-primary:hover {
    background: #0d5dd4;
  }
</style>
